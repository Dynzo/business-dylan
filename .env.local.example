# Kopieer dit bestand naar .env.local en vul de echte waarden in.
# Te vinden in je Supabase project: Settings → API Keys.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Secret key — nodig voor leads/companies/briefings/agent_runs (geen publieke RLS-policies).
# NOOIT client-side gebruiken.
SUPABASE_SECRET_KEY=

# Resend — voor de auto-reply naar de lead en de notificatiemail naar de beheerder.
# API key aanmaken op resend.com → API Keys.
RESEND_API_KEY=

# Verzendadres. Zonder eigen geverifieerd domein kun je Resend's test-domein gebruiken:
RESEND_FROM_EMAIL=onboarding@resend.dev

# E-mailadres van de beheerder die een notificatie krijgt bij elke nieuwe lead.
ADMIN_NOTIFICATION_EMAIL=

# Publieke site-URL — gebruikt in e-mails voor de link naar het beheerpaneel.
# Op Vercel wordt VERCEL_URL automatisch gezet; zet dit pas op je eigen domein zodra dat bekend is.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic — LLM voor de research-/enrichment-agent (Claude Haiku voor tussenstappen,
# Claude Sonnet voor de synthese/briefing). API key aanmaken op console.anthropic.com.
ANTHROPIC_API_KEY=

# Tavily — zoek- en extractie-API die de research-agent gebruikt voor openbaar webonderzoek.
# API key aanmaken op tavily.com.
TAVILY_API_KEY=
